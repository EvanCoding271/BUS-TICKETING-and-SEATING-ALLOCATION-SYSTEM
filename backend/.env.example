# Supabase/PostgreSQL connection string
DATABASE_URL=postgresql://username:password@host:5432/citybus

# JWT configuration
JWT_SECRET=super-secret-jwt-key
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=60

# Allowed front-end origins for CORS
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000
